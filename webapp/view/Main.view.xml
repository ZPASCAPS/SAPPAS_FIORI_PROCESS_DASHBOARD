<mvc:View
    controllerName="sappas.processdashboard.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">
    <Page
        id="mainPage"
        showNavButton="false"
        class="sappasMainPage"
        backgroundDesign="Solid">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="SAP Process Dashboard" level="H4" />
                </contentLeft>
                <contentMiddle>
                    <Text text="통합 업무 프로세스 대시보드" class="sappasPanelSubtitle" />
                </contentMiddle>
            </Bar>
        </customHeader>
        <content>
            <HBox
                width="100%"
                height="100%"
                alignItems="Stretch"
                class="sappasDashboardLayout">
                <VBox class="sappasPanel sappasPanel--left" height="100%">
                    <mvc:XMLView
                        viewName="sappas.processdashboard.view.features.ModuleSideNav"
                        height="100%" />
                </VBox>
                <VBox class="sappasPanel sappasPanel--center sappasCenterStack" height="100%">
                    <VBox class="sappasProcessArea" height="40%">
                        <mvc:XMLView
                            viewName="sappas.processdashboard.view.features.ProcessFlow"
                            height="100%" />
                    </VBox>
                    <VBox class="sappasReportArea" height="60%">
                        <mvc:XMLView
                            viewName="sappas.processdashboard.view.features.InventoryStatus"
                            height="33%" />
                        <mvc:XMLView
                            viewName="sappas.processdashboard.view.features.OrderImpact"
                            height="33%" />
                        <mvc:XMLView
                            viewName="sappas.processdashboard.view.features.MaterialShortage"
                            height="34%" />
                    </VBox>
                </VBox>
                <VBox class="sappasPanel sappasPanel--right" height="100%">
                    <mvc:XMLView
                        viewName="sappas.processdashboard.view.features.AiAssistant"
                        height="100%" />
                </VBox>
            </HBox>
        </content>
    </Page>
</mvc:View>
