<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    controllerName="sappas.processdashboard.controller.MainDashboard"
    displayBlock="true">
    <Page
        id="mainDashboardPage"
        title="SAP Process Dashboard"
        showNavButton="false"
        class="sappasMainPage"
        backgroundDesign="Solid">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="SAP Process Dashboard" level="H4" />
                </contentLeft>
                <contentMiddle>
                    <Text text="통합 업무 프로세스 대시보드" class="sappasPanelSubtitle" />
                </contentMiddle>
            </Bar>
        </customHeader>
        <content>
            <HBox
                width="100%"
                height="100%"
                alignItems="Stretch"
                class="sappasDashboardLayout">
                <VBox class="sappasPanel sappasPanel--left" height="100%">
                    <mvc:XMLView
                        viewName="sappas.processdashboard.view.module.ModuleSideNav"
                        height="100%" />
                </VBox>
                <VBox class="sappasPanel sappasPanel--center sappasCenterStack" height="100%">
                    <VBox class="sappasProcessArea" height="55%">
                        <mvc:XMLView
                            viewName="sappas.processdashboard.view.process.ProcessFlow"
                            height="100%" />
                    </VBox>
                    <VBox class="sappasDetailArea" height="45%">
                        <mvc:XMLView
                            viewName="sappas.processdashboard.view.process.DetailPanel"
                            height="100%" />
                    </VBox>
                </VBox>
                <VBox class="sappasPanel sappasPanel--right" height="100%">
                    <mvc:XMLView
                        viewName="sappas.processdashboard.view.chatbot.ChatbotPanel"
                        height="100%" />
                </VBox>
            </HBox>
        </content>
    </Page>
</mvc:View>
